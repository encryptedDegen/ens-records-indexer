{
	"name": "ens-records-indexer",
	"version": "0.1.0",
	"private": true,
	"description": "ENS records indexer that posts cache invalidations to ens-metadata-flarecloud",
	"license": "MIT",
	"main": "dist/index.js",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx watch src/index.ts",
		"start": "node --enable-source-maps dist/index.js",
		"lint": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"pino": "^9.5.0",
		"viem": "^2.21.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^20.16.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
